# Ignore log files and runtime data
*.log
*.log.gz
*.log.old
*.jsonl
*.pid
*.sha256

# Ignore generated files
__pycache__/
*.pyc
*.pyo

# Ignore large data files
*.csv
*.json
!picks.json
!positions.json
!derayah_tokens.json
!capital.json
!orders.json
!pm_cache.json
!regime.json

# Ignore session transcripts
archive/sessions/
*.log

# Ignore browser data
*.png
*.jpg
*.html.gz

# Ignore temp backups
backups/*.backup-*
*.tmp
*.temp
