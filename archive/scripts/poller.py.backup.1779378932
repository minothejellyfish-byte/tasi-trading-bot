# ─── Telegram ────────────────────────────────────────────────────────────────

def tg_send(text: str, chat_id: int = None, retries: int = 3):
    url = f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage"
    target = chat_id or CHAT_ID
    for attempt in range(retries):
        try:
            r = requests.post(
                url,
                json={"chat_id": target, "text": text, "parse_mode": "HTML"},
                timeout=10,
            )
            r.raise_for_status()
            return
        except Exception as e:
            log.error(f"tg_send failed (attempt {attempt+1}/{retries}): {e}")
            if attempt < retries - 1:
                time.sleep(2)


def auto_sell(symbol: str, qty, reason: str):
    base = symbol.replace(".SR", "")
    cmd  = f"SELL {base} {qty} MARKET"
    log.info(f"auto_sell: {cmd} | {reason}")
    tg_send(cmd, chat_id=EXEC_GROUP)
    tg_send(f"🤖 <b>Selling {base}</b> {qty} shares — order sent\n{reason}\n<i>Confirmation incoming...</i>")


def auto_buy(symbol: str, qty, cycle_n: int, max_cyc: int, price: float):
    base = symbol.replace(".SR", "")
    cmd  = f"BUY {base} {qty} MARKET"
    log.info(f"auto_buy: {cmd} | cycle {cycle_n}/{max_cyc} @ ~{price:.2f}")
    tg_send(cmd, chat_id=EXEC_GROUP)
    tg_send(f"🔄 <b>Cycle {cycle_n}/{max_cyc} — Buying {base}</b> {qty} shares @ ~{price:.2f} — order sent\n<i>Confirmation incoming...</i>")

# ─── State helpers ────────────────────────────────────────────────────────────

# Fallback logic
FALLBACK_TIME = time(10, 30)
